            <!-- ローカルルールベース高速生成ボタン -->
            <button @click="runLocalRuleBasedGeneration"
              class="w-full sm:w-auto px-12 py-4 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700 text-white rounded-xl text-lg font-bold shadow-lg transition-all transform hover:scale-[1.02] flex items-center justify-center gap-3">
              <span>⚡</span>
              高速チャート生成 (ルールベース)
            </button>
          </div>

          <!-- 結果エリア -->
          <div v-if="scheduleResults">
            <!-- サマリーカード -->
            <div class="bg-gradient-to-r from-blue-600 to-indigo-600 rounded-xl shadow-lg p-5 text-white mb-6">
              <div class="flex flex-wrap justify-between items-center gap-4">
                <div>
                  <div class="text-sm font-medium opacity-80">📊 シミュレーション結果</div>
                  <div class="text-xs opacity-60 mt-0.5">生成日時: {{ scheduleResults.generatedAt }}</div>
                </div>
                <div class="flex gap-8">
                  <div class="text-center">
                    <div class="text-3xl font-extrabold font-mono">{{ scheduleResults.totalRuns.toLocaleString() }}</div>
                    <div class="text-xs font-medium opacity-80">総周回数</div>
                  </div>
                  <div class="text-center">
                    <div class="text-3xl font-extrabold font-mono">{{ scheduleResults.phases.length }}</div>
                    <div class="text-xs font-medium opacity-80">フェーズ数</div>
                  </div>
                  <div class="text-center">
                    <div class="text-3xl font-extrabold font-mono">{{ scheduleResults.totalServants }}</div>
                    <div class="text-xs font-medium opacity-80">対象サーヴァント数</div>
                  </div>
                </div>

              <div class="mt-4 flex justify-end">
                <button @click="exportScheduleJSON" class="text-xs bg-white/20 hover:bg-white/30 px-3 py-1.5 rounded-md font-bold transition-colors">
                  📥 JSONとしてエクスポート
                </button>
              </div>
            </div>

            <!-- フェーズカード -->
            <div class="space-y-4">
              <div v-for="(phase, pIdx) in scheduleResults.phases" :key="phase.id"
                class="bg-white rounded-xl shadow-sm border overflow-hidden transition-all"
                :class="scheduleCheckpoints[phase.id] ? 'border-green-300 bg-green-50/30' : 'border-gray-200'">
                <!-- フェーズヘッダ -->
                <div class="px-5 py-3 flex items-center justify-between"
                  :class="scheduleCheckpoints[phase.id] ? 'bg-green-100' : 'bg-gray-50 border-b border-gray-200'">
                  <div class="flex items-center gap-3">
                    <span class="text-xs font-extrabold text-white px-2 py-1 rounded"
                      :class="scheduleCheckpoints[phase.id] ? 'bg-green-500' : 'bg-blue-600'">
                      Phase {{ pIdx + 1 }}
                    </span>
                    <span class="text-sm font-bold text-gray-700">{{ phase.questName }}</span>
                    <span class="text-xs text-gray-500">(基礎 {{ phase.baseBond.toLocaleString() }})</span>
                  </div>
                  <div class="flex items-center gap-3">
                    <span class="text-xl font-extrabold font-mono text-blue-700">{{ phase.runs.toLocaleString() }}<span class="text-sm font-bold text-gray-500">周</span></span>
                    <label class="flex items-center gap-1.5 cursor-pointer bg-gray-100 hover:bg-gray-200 px-3 py-1.5 rounded-md transition-colors">
                      <input type="checkbox" v-model="scheduleCheckpoints[phase.id]" @change="toggleCheckpoint(phase)" class="rounded border-gray-300 text-green-600 focus:ring-green-500 h-4 w-4">
                      <span class="text-xs font-bold" :class="scheduleCheckpoints[phase.id] ? 'text-green-600' : 'text-gray-500'">
                        {{ scheduleCheckpoints[phase.id] ? '完了!' : 'チェック' }}
                      </span>
                    </label>
                  </div>
                </div>

                <!-- 編成とCE -->
                <div class="p-5">
                  <div class="flex items-center gap-2 mb-3">
                    <span v-if="phase.mainTrait"
                      class="text-[10px] font-extrabold bg-yellow-100 text-yellow-800 border border-yellow-300 px-2 py-0.5 rounded-full">
                <div class="p-5">
                  <div class="flex items-center gap-2 mb-3">
                    <span v-if="phase.mainTrait"
                      class="text-[10px] font-extrabold bg-yellow-100 text-yellow-800 border border-yellow-300 px-2 py-0.5 rounded-full">
                      🎯 特性: {{ phase.mainTrait }}
                    </span>
                  </div>
                  
                  <!-- パーティメンバー (FGO編成画面風のミニカード) -->
                  <div class="flex flex-wrap gap-3 mb-4 overflow-x-auto pb-2 custom-scrollbar">
                    <div v-for="(member, idx) in phase.party" :key="idx"
                      class="flex-shrink-0 w-52 rounded-lg shadow-sm border border-gray-200 overflow-hidden flex flex-col transition-all duration-300 text-xs bg-white">
                      
                      <!-- カードヘッダ -->
                      <div class="px-2.5 py-1.5 border-b border-gray-200 flex justify-between items-center bg-gray-50">
                        <div class="flex items-center gap-1.5 min-w-0">
                          <span class="font-bold text-[10px] text-gray-500 bg-white px-2 py-0.5 rounded-full border border-gray-200 shrink-0">
                            Slot {{ idx + 1 }}
                          </span>
                          <img v-if="member.iconUrl" :src="member.iconUrl"
                            class="w-6 h-6 rounded-full border border-white object-cover shadow-sm shrink-0" />
                        </div>
                        <span v-if="member.completed" class="text-[9px] font-bold text-white bg-green-500 px-1.5 py-0.5 rounded shadow-sm shrink-0">達成!</span>
                      </div>

                      <!-- 設定表示エリア (縮小表示) -->
                      <div class="p-2.5 space-y-2 bg-gray-50/30 flex-1">
                        <div>
                          <label class="block text-[9px] font-bold text-gray-400 mb-0.5">サーヴァント</label>
                          <div class="font-bold text-gray-800 truncate text-[11px]" :title="member.name">
                            {{ member.name || '空き枠' }}
                          </div>
                        </div>

                        <div>
                          <label class="block text-[9px] font-bold text-gray-400 mb-0.5">装備礼装</label>
                          <div class="w-full bg-white border border-gray-200 rounded-md px-2 py-1 text-[10px] text-gray-700 truncate font-semibold">
                            🛡️ {{ formatCEName(member.equippedCE) }}
                          </div>
                        </div>

                        <div class="flex gap-2">
                          <div class="flex-1">
                            <label class="block text-[9px] font-bold text-gray-400 mb-0.5">配置ボーナス</label>
                            <div class="w-full bg-white border border-gray-200 rounded-md px-2 py-0.5 text-[10px] font-mono text-gray-700 font-bold truncate">
                              {{ phase.partyBonus && phase.partyBonus[idx] ? phase.partyBonus[idx].toFixed(2) + '倍' : '1.00倍' }}
                        </div>
                      </div>
                  <!-- CE配分 -->
                  <div class="flex flex-wrap gap-2 text-[10px] mt-3 bg-gray-50 p-2.5 rounded-lg border border-gray-200">
                    <div class="flex items-center gap-1 text-gray-500 font-bold shrink-0">
                      <span>🛡️</span> 自陣礼装:
                    </div>
                    <template v-for="(ce, idx) in phase.partyCEs" :key="idx">
                      <span v-if="ce !== 'none'" class="bg-indigo-50 text-indigo-700 border border-indigo-200 px-2 py-0.5 rounded font-bold">
                        Slot {{ idx + 1 }}: {{ formatCEName(ce) }}
                      </span>
                    </template>
                    <span class="text-gray-300 px-1 font-normal">|</span>
                    <div class="flex items-center gap-1 text-gray-500 font-bold shrink-0">
                      <span>🤝</span> フレンド:
                    </div>
                    <span v-for="(fCe, idx) in phase.friendCEs" :key="'f-'+idx" class="bg-amber-50 text-amber-700 border border-amber-200 px-2 py-0.5 rounded font-bold">
                      {{ fCe }}
                    </span>
                  </div>

                  <!-- 達成者 -->
                  <div v-if="phase.completedServants.length > 0" class="mt-3 pt-3 border-t border-gray-100">
                    <span class="text-xs font-bold text-green-600">
                      ✅ このフェーズで達成: {{ phase.completedServants.join(', ') }}
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

                    <div class="flex items-center gap-1 text-gray-500 font-bold shrink-0">
                      <span>🛡️</span> 自陣礼装:
                    <div class="flex items-center gap-1 text-gray-500 font-bold shrink-0">
                      <span>🛡️</span> 自陣礼装:
                    </div>
                    <template v-for="(ce, idx) in phase.partyCEs" :key="idx">
                      <span v-if="ce !== 'none'" class="bg-indigo-50 text-indigo-700 border border-indigo-200 px-2 py-0.5 rounded font-bold">
                        Slot {{ idx + 1 }}: {{ formatCEName(ce) }}
                      </span>
                    </template>
                    <span class="text-gray-300 px-1 font-normal">|</span>
                    <div class="flex items-center gap-1 text-gray-500 font-bold shrink-0">
                      <span>🤝</span> フレンド:
                    </div>
                    <span v-for="(fCe, idx) in phase.friendCEs" :key="'f-'+idx" class="bg-amber-50 text-amber-700 border border-amber-200 px-2 py-0.5 rounded font-bold">
                      {{ fCe }}
                    </span>
                  </div>

                  <!-- 達成者 -->
                  <div v-if="phase.completedServants.length > 0" class="mt-3 pt-3 border-t border-gray-100">
                    <span class="text-xs font-bold text-green-600">
                      ✅ このフェーズで達成: {{ phase.completedServants.join(', ') }}
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="bondReqs.js"></script>
  <script src="app.js"></script>
</body>

</html>
