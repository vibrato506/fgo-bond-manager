            :class="currentParty.isGrand && currentParty.isGrand[index] ? 'bg-blue-50/30 border-2 border-blue-500 shadow-blue-200' : 'bg-white border border-gray-200'">

            <!-- カードヘッダ -->
            <div class="px-4 py-3 border-b flex justify-between items-center"
